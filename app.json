{
  "expo": {
    "name": "Heitje voor een karweitje",
    "slug": "heitje-voor-een-karweitje",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "primaryColor": "#7C3AED",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C3AED"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "nl.heitje.karweitje",
      "infoPlist": {
        "NSCameraUsageDescription": "Heitje uses the camera for before/after photos of chores.",
        "NSPhotoLibraryUsageDescription": "Heitje uses your photo library for savings goal images."
      }
    },
    "android": {
      "package": "nl.heitje.karweitje",
      "permissions": ["CAMERA"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      }
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Heitje uses the camera for before/after photos of chores.",
          "photosPermission": "Heitje uses your photo library for savings goal images."
        }
      ]
    ]
  }
}
